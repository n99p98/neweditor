APP_NAME="PrintFold Studio API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:9000
FRONTEND_URL=http://localhost:3000
DB_CONNECTION=mysql
# For Docker Compose use `mysql`; for local macOS/Homebrew use `127.0.0.1`.
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=printfold
DB_USERNAME=printfold
DB_PASSWORD=secret
CACHE_STORE=redis
QUEUE_CONNECTION=redis
# For Docker Compose use `redis`; for local macOS/Homebrew use `127.0.0.1`.
REDIS_HOST=redis
FILESYSTEM_DISK=local
STRIPE_SECRET=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:9000/api/auth/social/google/callback
HD_EXPORT_PRICE=9.99
